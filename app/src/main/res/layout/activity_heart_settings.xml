<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/settings_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/settings_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textColor="@color/settings_text_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/settings_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/settings_subtitle"
            android:textColor="@color/settings_text_secondary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/sent_beat_count_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/sent_beat_count"
            android:textColor="@color/settings_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/sent_beat_count_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/settings_text_primary"
            android:textSize="48sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/received_beat_count_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/received_beat_count"
            android:textColor="@color/settings_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/received_beat_count_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/settings_text_primary"
            android:textSize="48sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/pairing_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/pairing_status"
            android:textColor="@color/settings_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/pairing_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/settings_text_primary"
            android:textSize="18sp" />

        <Button
            android:id="@+id/create_identity_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="20dp"
            android:text="@string/create_identity" />

        <Button
            android:id="@+id/simulate_pending_pairing_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="@string/simulate_pending_pairing" />

        <Button
            android:id="@+id/simulate_paired_partner_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="@string/simulate_paired_partner" />

        <Button
            android:id="@+id/reset_pairing_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="@string/reset_pairing" />

        <Button
            android:id="@+id/send_beat_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="32dp"
            android:text="@string/send_test_beat" />

        <Button
            android:id="@+id/simulate_incoming_beat_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="@string/simulate_incoming_beat" />

        <Button
            android:id="@+id/simulate_many_incoming_beats_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="@string/simulate_many_incoming_beats" />

        <Button
            android:id="@+id/reset_received_count_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="@string/reset_received_count" />

        <Button
            android:id="@+id/reset_all_counts_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="@string/reset_all_counts" />

        <Button
            android:id="@+id/refresh_widget_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="@string/refresh_widgets" />

    </LinearLayout>
</ScrollView>
