rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsPairCode(pairCode) {
      return signedIn()
        && exists(/databases/$(database)/documents/pairCodes/$(pairCode))
        && get(/databases/$(database)/documents/pairCodes/$(pairCode)).data.ownerUserId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn()
        && (
          request.auth.uid == userId
          || (
            resource.data.partnerId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['receivedUnreadBeatCount', 'lastReceivedBeatAt', 'updatedAt'])
          )
        );
    }

    match /pairCodes/{pairCode} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.ownerUserId == request.auth.uid;
    }

    match /pairRequests/{requestId} {
      allow read: if signedIn()
        && (
          resource.data.fromUserId == request.auth.uid
          || ownsPairCode(resource.data.toPairCode)
        );
      allow create: if signedIn()
        && request.resource.data.fromUserId == request.auth.uid;
      allow update: if signedIn()
        && (
          resource.data.fromUserId == request.auth.uid
          || ownsPairCode(resource.data.toPairCode)
        );
    }

    match /incomingPairRequests/{pairCode} {
      allow read: if signedIn()
        && (
          ownsPairCode(pairCode)
          || resource.data.fromUserId == request.auth.uid
        );
      allow create: if signedIn()
        && request.resource.data.fromUserId == request.auth.uid;
      allow update: if signedIn()
        && (
          ownsPairCode(pairCode)
          || resource.data.fromUserId == request.auth.uid
        );
    }
  }
}
