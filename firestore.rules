rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsPairCode(pairCode) {
      return signedIn()
        && exists(/databases/$(database)/documents/pairCodes/$(pairCode))
        && get(/databases/$(database)/documents/pairCodes/$(pairCode)).data.ownerUserId == request.auth.uid;
    }

    function acceptedPairRequestAllowsBeat(targetUserId) {
      let sender = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      let pairRequest = get(/databases/$(database)/documents/pairRequests/$(sender.pairRequestId)).data;
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && sender.partnerId == targetUserId
        && sender.pairRequestId is string
        && exists(/databases/$(database)/documents/pairRequests/$(sender.pairRequestId))
        && pairRequest.status == 'accepted'
        && (
          (
            pairRequest.fromUserId == request.auth.uid
            && pairRequest.acceptedByUserId == targetUserId
          )
          || (
            pairRequest.fromUserId == targetUserId
            && pairRequest.acceptedByUserId == request.auth.uid
          )
        );
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn()
        && (
          request.auth.uid == userId
          || (
            acceptedPairRequestAllowsBeat(userId)
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['receivedUnreadBeatCount', 'lastReceivedBeatAt', 'updatedAt'])
          )
        );
    }

    match /pairCodes/{pairCode} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.ownerUserId == request.auth.uid;
    }

    match /pairRequests/{requestId} {
      allow read: if signedIn()
        && (
          resource.data.fromUserId == request.auth.uid
          || ownsPairCode(resource.data.toPairCode)
        );
      allow create: if signedIn()
        && request.resource.data.fromUserId == request.auth.uid;
      allow update: if signedIn()
        && ownsPairCode(resource.data.toPairCode)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'acceptedByUserId', 'acceptedByPairCode', 'acceptedAt', 'updatedAt'])
        && request.resource.data.status == 'accepted'
        && request.resource.data.acceptedByUserId == request.auth.uid
        && request.resource.data.acceptedByPairCode == resource.data.toPairCode;
    }

    match /incomingPairRequests/{pairCode} {
      allow read: if signedIn()
        && (
          ownsPairCode(pairCode)
          || resource.data.fromUserId == request.auth.uid
        );
      allow create: if signedIn()
        && request.resource.data.fromUserId == request.auth.uid;
      allow update: if signedIn()
        && ownsPairCode(pairCode)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['requestId', 'status', 'acceptedByUserId', 'acceptedByPairCode', 'acceptedAt', 'updatedAt'])
        && request.resource.data.status == 'accepted'
        && request.resource.data.acceptedByUserId == request.auth.uid
        && request.resource.data.acceptedByPairCode == pairCode;
    }
  }
}
